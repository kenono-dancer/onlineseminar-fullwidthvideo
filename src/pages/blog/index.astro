---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import categoryMap from '../../data/categoryMap.json';
import tagMap from '../../data/tagMap.json';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    const dateA = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
    const dateB = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
    return dateB - dateA;
  });

const catMap = new Map((Object.entries(categoryMap) as unknown) as [string, string][]);
const tMap = new Map((Object.entries(tagMap) as unknown) as [string, string][]);

// Collect all unique tags from blog posts
const allTags: string[] = [];
posts.forEach((post) => {
  if (post.data.tags) {
    post.data.tags.forEach((tag: string) => {
      if (!allTags.includes(tag)) {
        allTags.push(tag);
      }
    });
  }
});

// Collect all unique years from blog posts
const allYears: number[] = [];
posts.forEach((post) => {
  if (post.data.pubDate) {
    const year = post.data.pubDate.getFullYear();
    if (!allYears.includes(year)) {
      allYears.push(year);
    }
  }
});
allYears.sort((a, b) => b - a);

// Serialize posts data for client-side filtering
const serializedPosts = posts.map((post) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description || '',
  heroImage: post.data.heroImage || '',
  pubDate: post.data.pubDate ? post.data.pubDate.toISOString() : '',
  categories: post.data.categories || [],
  tags: post.data.tags || [],
  year: post.data.pubDate ? post.data.pubDate.getFullYear() : 0,
  catLabels: (post.data.categories || []).map((cat: string) => catMap.get(cat) ?? cat),
}));
---

<Layout title="新着一覧 - オンライン社交ダンスセミナー" description="社交ダンスに関する記事や動画の一覧です。タグや開催年で絞り込みができます。">
  <main class="container mx-auto px-4 py-16 mt-16 max-w-5xl">
    <h1 class="text-4xl lg:text-5xl text-center mb-4 text-primary font-heading">新着一覧</h1>
    <p class="text-center text-muted-foreground mb-10" id="post-count">{posts.length} 件</p>

    <!-- Sub Navigation -->
    <div class="mb-10 space-y-6">
      <!-- Year Filter -->
      <div>
        <h3 class="font-heading text-sm font-bold text-primary mb-3 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          開催年
        </h3>
        <div class="flex flex-wrap gap-2" id="year-filters">
          <button
            class="filter-btn filter-btn--year active px-3 py-1.5 rounded-full text-xs font-semibold border transition-all cursor-pointer bg-primary text-primary-foreground border-primary"
            data-year="all"
          >
            すべて
          </button>
          {allYears.map((year) => (
            <button
              class="filter-btn filter-btn--year px-3 py-1.5 rounded-full text-xs font-semibold border transition-all cursor-pointer bg-card text-muted-foreground border-border hover:border-primary hover:text-primary"
              data-year={String(year)}
            >
              {year}年
            </button>
          ))}
        </div>
      </div>

      <!-- Tag Filter -->
      <div>
        <h3 class="font-heading text-sm font-bold text-primary mb-3 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>
          タグ
        </h3>
        <div class="flex flex-wrap gap-2" id="tag-filters">
          <button
            class="filter-btn filter-btn--tag active px-3 py-1.5 rounded-full text-xs font-semibold border transition-all cursor-pointer bg-primary text-primary-foreground border-primary"
            data-tag="all"
          >
            すべて
          </button>
          {allTags.map((tag) => (
            <button
              class="filter-btn filter-btn--tag px-3 py-1.5 rounded-full text-xs font-semibold border transition-all cursor-pointer bg-card text-muted-foreground border-border hover:border-primary hover:text-primary"
              data-tag={tag}
            >
              {tMap.get(tag) ?? tag}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Posts Grid -->
    <div class="grid gap-8" id="posts-grid">
      {posts.map((post) => (
        <article
          id={`post-${post.id}`}
          class="blog-post bg-card rounded-2xl p-6 shadow-sm border border-border flex flex-col sm:flex-row gap-6 hover:shadow-md transition-shadow"
          data-tags={JSON.stringify(post.data.tags || [])}
          data-year={post.data.pubDate ? String(post.data.pubDate.getFullYear()) : ''}
        >
          {post.data.heroImage && (
            <a href={`/blog/${post.id}`} class="block shrink-0">
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                width="240"
                height="135"
                loading="lazy"
                class="w-full sm:w-[240px] h-[135px] object-cover rounded-xl hover:opacity-80 transition-opacity"
              />
            </a>
          )}
          <div class="flex-1 flex flex-col justify-center">
            <h2 class="text-2xl mb-2 font-heading">
              <a href={`/blog/${post.id}`} class="hover:text-primary transition-colors">{post.data.title}</a>
            </h2>
            <div class="flex flex-wrap gap-3 text-sm text-muted-foreground mb-3 font-medium">
              {post.data.pubDate && (
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('ja-JP')}
                </time>
              )}
              {post.data.categories && post.data.categories.length > 0 && (
                <div class="flex gap-2">
                  {post.data.categories.map((cat: string) => (
                    <span class="bg-secondary text-secondary-foreground px-2 py-0.5 rounded-full text-xs">
                      {catMap.get(cat) ?? cat}
                    </span>
                  ))}
                </div>
              )}
            </div>
            {post.data.description && (
              <a href={`/blog/${post.id}`} class="block hover:opacity-70 transition-opacity">
                <p class="text-foreground/80 line-clamp-2">{post.data.description}</p>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- No results message -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-muted-foreground text-lg">該当する記事が見つかりませんでした。</p>
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    let activeYear = 'all';
    let activeTag = 'all';

    const yearButtons = document.querySelectorAll('.filter-btn--year');
    const tagButtons = document.querySelectorAll('.filter-btn--tag');
    const posts = document.querySelectorAll('.blog-post');
    const postCount = document.getElementById('post-count');
    const noResults = document.getElementById('no-results');

    const activeClass = 'bg-primary text-primary-foreground border-primary';
    const inactiveClass = 'bg-card text-muted-foreground border-border hover:border-primary hover:text-primary';

    function setActive(button: Element, group: NodeListOf<Element>) {
      group.forEach((btn) => {
        btn.className = btn.className
          .replace(/bg-primary/g, 'bg-card')
          .replace(/text-primary-foreground/g, 'text-muted-foreground')
          .replace(/border-primary/g, 'border-border');
        if (!btn.className.includes('hover:border-primary')) {
          btn.className += ' hover:border-primary hover:text-primary';
        }
        btn.classList.remove('active');
      });
      button.className = button.className
        .replace(/bg-card/g, 'bg-primary')
        .replace(/text-muted-foreground/g, 'text-primary-foreground')
        .replace(/border-border/g, 'border-primary')
        .replace(/hover:border-primary/g, '')
        .replace(/hover:text-primary/g, '');
      button.classList.add('active');
    }

    function filterPosts() {
      let visibleCount = 0;

      posts.forEach((post) => {
        const el = post as HTMLElement;
        const postYear = el.dataset.year || '';
        const postTags: string[] = JSON.parse(el.dataset.tags || '[]');

        const yearMatch = activeYear === 'all' || postYear === activeYear;
        const tagMatch = activeTag === 'all' || postTags.includes(activeTag);

        if (yearMatch && tagMatch) {
          el.style.display = '';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });

      if (postCount) {
        postCount.textContent = `${visibleCount} 件`;
      }

      if (noResults) {
        noResults.classList.toggle('hidden', visibleCount > 0);
      }
    }

    yearButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeYear = (btn as HTMLElement).dataset.year || 'all';
        setActive(btn, yearButtons);
        filterPosts();
      });
    });

    tagButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeTag = (btn as HTMLElement).dataset.tag || 'all';
        setActive(btn, tagButtons);
        filterPosts();
      });
    });
  });
</script>

<style>
  .filter-btn {
    transition: all 0.2s ease;
  }
  .filter-btn:hover {
    transform: translateY(-1px);
  }
  .filter-btn.active {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  .blog-post {
    scroll-margin-top: 8rem;
  }
</style>
