---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import HomePage from '../components/HomePage';

const allSeminarPosts = (await getCollection('blog', ({ data }) => !data.draft && data.categories.includes('online-lesson')))
  .sort((a, b) => {
    const dateA = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
    const dateB = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
    return dateB - dateA;
  });

const posts = allSeminarPosts
  .slice(0, 100)
  .map(post => ({
    id: post.id,
    title: post.data.title,
    description: post.data.description || '',
    heroImage: post.data.heroImage || '/images/meditating_cat_illustration.png',
  }));

const nextPostId = allSeminarPosts.length > 100 ? allSeminarPosts[100].id : '';
const totalSeminarCount = allSeminarPosts.length;
---

<Layout
  title="オンライン社交ダンスセミナー/大埜 健のオンライン社交ダンスレッスン"
  description="Find your zen with cat-inspired meditation. Guided breathing exercises, mindfulness sessions, and feline wisdom to help you relax. One breath, one paw print at a time."
  canonicalPath="/"
>
  {/* Background video rendered as static HTML to ensure muted attribute is in DOM for iOS autoplay */}
  <div id="hero-video-container" style="position:absolute;left:0;width:100%;z-index:0;pointer-events:none;overflow:hidden;visibility:hidden;">
    <video
      id="hero-bg-video"
      autoplay
      loop
      muted
      playsinline
      webkit-playsinline
      preload="auto"
      style="width:100%;height:100%;object-fit:cover;"
    >
      <source src="/videos/dance-logic.mp4" type="video/mp4" />
    </video>
  </div>
  <script is:inline>
    function alignVideoToHero() {
      var container = document.getElementById('hero-video-container');
      var heroDiv = document.querySelector('#home > div');
      if (!container || !heroDiv) return false;
      // READ phase: batch all layout reads first
      var rect = heroDiv.getBoundingClientRect();
      var scrollY = window.pageYOffset || document.documentElement.scrollTop;
      var top = rect.top + scrollY;
      var height = rect.height;
      // WRITE phase: defer DOM mutations to next frame to avoid forced reflow
      requestAnimationFrame(function () {
        container.style.top = top + 'px';
        container.style.height = height + 'px';
        container.style.visibility = 'visible';
      });
      return true;
    }
    function initHeroVideo() {
      if (!alignVideoToHero()) {
        requestAnimationFrame(initHeroVideo);
        return;
      }
      // Debounce resize: avoid repeated layout reads during window resize
      var _resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(_resizeTimer);
        _resizeTimer = setTimeout(alignVideoToHero, 100);
      }, { passive: true });
      var v = document.getElementById('hero-bg-video');
      if (v) {
        v.muted = true;
        v.setAttribute('muted', '');
        v.play().catch(function() {});
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroVideo);
    } else {
      initHeroVideo();
    }
  </script>
  <HomePage posts={posts} nextPostId={nextPostId} totalCount={totalSeminarCount} client:load />
</Layout>
