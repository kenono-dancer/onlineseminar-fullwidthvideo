---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import categoryMap from '../data/categoryMap.json';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);
  const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => {
      const dateB = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
      const dateA = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
      return dateB - dateA;
    });

  const existingFiles = ['about', 'app', 'contact', 'explore', 'faq', 'guide', 'index', 'join', 'privacy', 'blog'];
  
  const pagePaths = pages
    .filter((page) => !existingFiles.includes(page.id))
    .map((page) => ({
      params: { id: page.id },
      props: { type: 'page', data: page },
    }));

  const postPaths = posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      type: 'blog',
      data: post,
      prev: posts[index + 1] || null,
      next: posts[index - 1] || null,
      allPosts: posts.slice(0, 30),
    },
  }));

  return [...pagePaths, ...postPaths];
}

const { type, data, prev, next, allPosts } = Astro.props;
const { Content } = await render(data as any);

const catMap = new Map((Object.entries(categoryMap) as unknown) as [string, string][]);

const truncateTitle = (title: string, length: number) => {
  if (title.length <= length) return title;
  return title.slice(0, length) + '...';
};
---

{type === 'page' ? (
  <Layout title={`${data.data.title} - オンライン社交ダンスセミナー`} description={data.data.description || 'Page'}>
    <main class="container mx-auto px-4 py-16 mt-16 max-w-3xl">
      <article class="prose prose-stone lg:prose-lg mx-auto bg-card p-6 sm:p-10 rounded-3xl shadow-sm border border-border">
        {data.data.heroImage && data.id !== 'ken-ono' && (
          <img
            src={data.data.heroImage}
            alt=""
            class="w-full h-auto rounded-2xl mb-8 object-cover"
          />
        )}
        
        <div class="mb-8 border-b border-border pb-6">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading mb-4 text-primary leading-tight">
            {data.data.title}
          </h1>
        </div>
        
        <div class="mt-8 markdown-body">
          <Content />
        </div>
      </article>
    </main>
  </Layout>
) : (
  <Layout title={`${data.data.title} - オンライン社交ダンスセミナー`} description={data.data.description || 'セミナー内容の解説'}>
    <main class="container mx-auto px-4 py-16 mt-16 max-w-6xl">
      <div class="lg:grid lg:grid-cols-[1fr_260px] lg:gap-12">
        {/* Main Content Column */}
        <div class="space-y-8">
          {/* Top Navigation Buttons */}
          <nav class="flex justify-between items-center bg-card p-4 rounded-2xl border border-border mb-4 shadow-sm">
            <div class="w-1/2">
              {prev && (
                <a href={`/${prev.id}`} class="flex items-center gap-2 text-primary hover:text-primary/80 font-bold transition-all text-sm group">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
                  前のセミナー
                </a>
              )}
            </div>
            <div class="w-1/2 flex justify-end">
              {next && (
                <a href={`/${next.id}`} class="flex items-center gap-2 text-primary hover:text-primary/80 font-bold transition-all text-sm group">
                  次のセミナー
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              )}
            </div>
          </nav>

          <article class="prose prose-stone lg:prose-lg mx-auto bg-card p-6 sm:p-10 rounded-3xl shadow-sm border border-border">
            {data.data.heroImage && (
              <img
                src={data.data.heroImage}
                alt=""
                class="w-full h-auto rounded-2xl mb-8 object-cover"
              />
            )}
            
            <div class="mb-8 border-b border-border pb-6">
              <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading mb-4 text-primary leading-tight">
                {data.data.title}
              </h1>
              
              <div class="flex flex-wrap gap-4 items-center text-muted-foreground text-sm font-medium">
                {data.data.pubDate && (
                   <time datetime={data.data.pubDate.toISOString()}>
                     {data.data.pubDate.toLocaleDateString('ja-JP')}
                   </time>
                )}
                
                {data.data.categories && data.data.categories.length > 0 && (
                   <div class="flex gap-2">
                     {data.data.categories.map((cat: string) => (
                       <a href={`/category/${cat}/`} class="bg-secondary text-secondary-foreground px-2 py-0.5 rounded-full text-xs hover:bg-primary hover:text-primary-foreground transition-colors">
                         {catMap.get(cat) ?? cat}
                       </a>
                     ))}
                   </div>
                )}
              </div>
            </div>
            
            <div class="mt-8 markdown-body">
              <Content />
            </div>
          </article>

          {/* Bottom Navigation Buttons */}
          <nav class="bg-card p-8 rounded-3xl border border-border mt-8 shadow-sm space-y-8">
            <div class="flex flex-col sm:flex-row justify-between gap-8">
              <div class="flex-1">
                {prev && (
                  <a href={`/${prev.id}`} class="flex flex-col gap-3 group">
                    <span class="text-xs text-muted-foreground flex items-center gap-1 group-hover:text-primary transition-colors font-bold tracking-wider">
                       <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                       前のセミナーへ
                    </span>
                    <span class="text-foreground font-bold group-hover:text-primary transition-colors line-clamp-2 text-base md:text-lg leading-relaxed">
                      {prev.data.title}
                    </span>
                  </a>
                )}
              </div>
              <div class="flex-1 flex flex-col items-end text-right group">
                {next && (
                  <a href={`/${next.id}`} class="flex flex-col gap-3 transition-all">
                    <span class="text-xs text-muted-foreground flex items-center gap-1 justify-end group-hover:text-primary transition-colors font-bold tracking-wider">
                       次のセミナーへ
                       <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                    </span>
                    <span class="text-foreground font-bold group-hover:text-primary transition-colors line-clamp-2 text-base md:text-lg leading-relaxed">
                      {next.data.title}
                    </span>
                  </a>
                )}
              </div>
            </div>
            <div class="pt-8 border-t border-border flex justify-center">
              <a href="/blog/" class="flex items-center gap-2 bg-primary text-primary-foreground px-8 py-3 rounded-full font-bold shadow-lg shadow-primary/20 hover:scale-105 hover:shadow-xl transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                セミナー内容一覧へ
              </a>
            </div>
          </nav>
        </div>

        {/* Sidebar Column */}
        <aside class="hidden lg:block space-y-8 mt-4">
          <div class="bg-card rounded-3xl p-6 border border-border shadow-sm sticky top-32">
            <h2 class="font-heading text-lg font-bold text-primary mb-6 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
              過去の投稿
            </h2>
            <nav class="space-y-4 max-h-[70vh] overflow-y-auto pr-2 custom-scrollbar">
              {allPosts.map((p: any) => (
                <a 
                  href={`/${p.id}`} 
                  class={`block text-sm p-2 rounded-xl transition-all hover:bg-primary/10 ${p.id === data.id ? 'bg-primary/20 text-primary font-bold border-l-4 border-primary' : 'text-foreground/70 border-l-4 border-transparent'}`}
                >
                  <time class="text-[10px] block opacity-60 mb-1">{p.data.pubDate?.toLocaleDateString('ja-JP')}</time>
                  {truncateTitle(p.data.title, 20)}
                </a>
              ))}
              <div class="mt-6 pt-6 border-t border-border">
                <a href="/blog" class="text-primary hover:text-primary/80 font-bold text-sm block text-center bg-primary/5 py-3 rounded-full transition-colors">
                  もっと見る
                </a>
              </div>
            </nav>
          </div>
        </aside>
      </div>
    </main>
  </Layout>
)}

<style is:global>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }
</style>


