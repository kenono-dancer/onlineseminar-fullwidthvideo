---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);
  // Avoid conflicts with hardcoded pages in the new theme
  const existingFiles = ['about', 'app', 'contact', 'explore', 'faq', 'guide', 'index', 'join', 'privacy'];
  return pages
    .filter((page) => !existingFiles.includes(page.id))
    .map((page) => ({
      params: { id: page.id },
      props: page,
    }));
}

const page = Astro.props;
const { Content } = await render(page);
---

<Layout title={`${page.data.title} - オンライン社交ダンスセミナー`} description={page.data.description || 'Page'}>
  <main class="container mx-auto px-4 py-16 mt-16 max-w-3xl">
    <article class="prose prose-stone lg:prose-lg mx-auto bg-card p-6 sm:p-10 rounded-3xl shadow-sm border border-border">
      {page.data.heroImage && page.id !== 'ken-ono' && (
        <img
          src={page.data.heroImage}
          alt=""
          class="w-full h-auto rounded-2xl mb-8 object-cover"
        />
      )}
      
      <div class="mb-8 border-b border-border pb-6">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading mb-4 text-primary leading-tight">
          {page.data.title}
        </h1>
      </div>
      
      <div class="mt-8 markdown-body">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style is:global>
  .markdown-body h2 {
    font-size: 1.8rem;
    font-family: var(--font-heading);
    color: hsl(var(--primary));
    margin-top: 2rem;
    margin-bottom: 1rem;
    scroll-margin-top: 8rem;
  }
  .markdown-body h3 {
    font-size: 1.5rem;
    font-family: var(--font-heading);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 8rem;
  }
  .markdown-body p {
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }
  .markdown-body ul {
    list-style-type: disc;
    margin-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .markdown-body ol {
    list-style-type: decimal;
    margin-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .markdown-body a {
    color: hsl(var(--primary));
    text-decoration: underline;
  }
  .markdown-body img {
    border-radius: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .markdown-body blockquote {
    border-left: 4px solid hsl(var(--primary));
    padding-left: 1rem;
    color: hsl(var(--muted-foreground));
    font-style: italic;
  }
</style>
